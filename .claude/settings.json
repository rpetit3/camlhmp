{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(poetry:*)",
      "Bash(just:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(blastn:*)",
      "Bash(tblastn:*)",
      "Bash(camlhmp:*)",
      "Bash(camlhmp-blast-alleles:*)",
      "Bash(camlhmp-blast-regions:*)",
      "Bash(camlhmp-blast-targets:*)",
      "Bash(camlhmp-blast-thresholds:*)",
      "Bash(camlhmp-extract:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/catalog-reminder.py\""
          }
        ]
      }
    ]
  }
}
